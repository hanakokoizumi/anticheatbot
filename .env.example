# 复制为 .env 后填写。勿提交真实 .env。

# Telegram（必填）
BOT_TOKEN=

# Mini App 对外 HTTPS 根地址（须 https://；主机名需与 @BotFather 里 Mini App 域名一致；无末尾斜杠）
WEBAPP_PUBLIC_URL=https://example.com

# HTTP 服务（Mini App 静态页与 /api 同源）
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# 可选：静态资源目录（默认使用当前工作目录下的 ./webapp）。Docker/安装包场景若 cwd 无 webapp 则需设置
# WEBAPP_ROOT=/absolute/path/to/webapp

# 数据库：本地开发默认 SQLite；Docker Compose 下由 compose 注入 Postgres URL
DATABASE_URL=sqlite+aiosqlite:///./data/bot.db

# WebApp initData 最大允许年龄（秒）
INIT_DATA_MAX_AGE_SECONDS=86400

# OpenAI 兼容 API（翻译与审查；可留空则关闭对应能力）
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# TRANSLATE_MODEL=
# MODERATION_MODEL=

TRANSLATION_PROMPT_VERSION=1

# Cloudflare Turnstile（可选；群设置里开启后必填密钥）
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# 全局管理员（最高权限）：可管理任意已知群组、跳过入群验证与 LLM 审查；逗号分隔数字 ID
GLOBAL_ADMIN_USER_IDS=
# 兼容旧变量名，与 GLOBAL_ADMIN_USER_IDS 合并为同一集合
ADMIN_USER_IDS=
